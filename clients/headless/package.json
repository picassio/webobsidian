{
  "name": "web-vault-sync",
  "version": "0.1.0",
  "description": "Revision-safe Linux filesystem client and daemon for WebObsidian Central Sync",
  "type": "module",
  "bin": { "web-vault-sync": "dist/cli.js" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "packaging", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@picassio/sync-core": "0.1.2",
    "chokidar": "^4.0.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": { "node": ">=20" },
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/picassio/webobsidian.git", "directory": "clients/headless" }
}
